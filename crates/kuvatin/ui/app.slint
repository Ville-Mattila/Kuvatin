import { Button, ComboBox, ProgressIndicator, ListView, LineEdit, SpinBox, CheckBox } from "std-widgets.slint";

export struct FileRow {
    name: string,
    status: string,
    thumb: image,
    dims: string,
    cropped: bool,
}

// A clip placed on the video timeline. Positions are in seconds; the UI maps
// them to pixels via the pixels-per-second zoom.
export struct TimelineClip {
    id: string,        // GES clip name (identifies the clip for edits)
    track: int,        // 0 = bottom layer
    start: float,      // seconds from the timeline origin
    duration: float,   // seconds
    inpoint: float,    // seconds into the source (trim offset)
    name: string,
    kind: int,         // 0 = video, 1 = image
    selected: bool,
    thumb: image,
}

// A media-bin entry: file name + a generated thumbnail.
export struct VideoAsset {
    name: string,
    thumb: image,
}

// Palette ---------------------------------------------------------------
// window     #16181d
// card       #20242c   border #2c313b   radius 10px
// text       #f2f4f8   muted  #9aa3b2
// accent     #2dd4bf   (hover/pressed #14b8a6)
// danger     #f87171

// A clearly visible, fully custom quality slider (0..100). Replaces the
// std-widgets Slider, which rendered invisibly against the dark theme.
component QualitySlider inherits Rectangle {
    in-out property <int> value;
    // Pin the height: inside a layout a plain `height` is only a preferred size
    // and the slider would stretch to fill extra vertical space (dropping the
    // track to the middle). min/max keep it a fixed 24px row.
    min-height: 24px;
    max-height: 24px;
    horizontal-stretch: 1;
    // Do not absorb the panel's extra vertical space (that's the spacer's job);
    // otherwise the QUALITY group stretches and the slider drops to its middle.
    vertical-stretch: 0;

    // track
    Rectangle {
        y: parent.height / 2 - 3px;
        height: 6px;
        border-radius: 3px;
        background: #2c313b;
        // filled portion
        Rectangle {
            x: 0;
            width: parent.width * (root.value / 100.0);
            height: parent.height;
            border-radius: 3px;
            background: #2dd4bf;
        }
    }

    // knob
    Rectangle {
        width: 16px;
        height: 16px;
        border-radius: 8px;
        background: ta.has-hover || ta.pressed ? #e6fffb : white;
        border-width: 2px;
        border-color: #2dd4bf;
        y: parent.height / 2 - 8px;
        x: (root.width - 16px) * (root.value / 100.0);
    }

    ta := TouchArea {
        function set(mx: length) {
            root.value = Math.clamp(Math.round(mx / root.width * 100), 0, 100);
        }
        moved => { ta.set(ta.mouse-x); }
        clicked => { ta.set(ta.mouse-x); }
    }
}

// A card surface used for the two main panels.
component Card inherits Rectangle {
    background: #20242c;
    border-radius: 10px;
    border-width: 1px;
    border-color: #2c313b;
}

// Secondary (card-colored) button used for Add/Clear.
component SecondaryButton inherits Rectangle {
    in property <string> text;
    callback clicked();
    height: 34px;
    min-width: 96px;
    border-radius: 8px;
    border-width: 1px;
    border-color: #2c313b;
    background: ta.pressed ? #2c313b : (ta.has-hover ? #262b34 : #20242c);
    Text {
        text: root.text;
        color: #f2f4f8;
        font-size: 13px;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
    ta := TouchArea {
        clicked => { root.clicked(); }
    }
}

// Field label: bold, muted.
component FieldLabel inherits Text {
    color: #9aa3b2;
    font-size: 12px;
    font-weight: 700;
}

// One resize handle for a corner of the crop rectangle. It owns its own drag
// bookkeeping (start values captured on press) and reports the dragged corner
// position back as normalized deltas via the `dragged` callback.
component CropHandle inherits Rectangle {
    in property <float> box-w;
    in property <float> box-h;
    // Which corner: -1 = left/top edge moves, +1 = right/bottom edge moves.
    in property <float> sign-x;
    in property <float> sign-y;
    // Fired when the drag starts, so the owner can capture the edges to offset.
    callback pressed();
    // dx, dy are normalized (0..1) drag deltas since press.
    callback dragged(float, float);

    // Large transparent hit area so the corner is easy to grab; the visible
    // square is centered within it. The TouchArea fills `root`.
    width: 32px;
    height: 32px;
    background: transparent;

    property <length> sx;
    property <length> sy;

    // Visible handle: a smaller teal square with a dark outline, centered.
    Rectangle {
        width: 18px;
        height: 18px;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        border-radius: 5px;
        background: ha.pressed ? #14b8a6 : #2dd4bf;
        border-width: 2px;
        border-color: #08110f;
    }

    ha := TouchArea {
        mouse-cursor: move;
        pointer-event(ev) => {
            if (ev.kind == PointerEventKind.down) {
                root.sx = self.mouse-x;
                root.sy = self.mouse-y;
                root.pressed();
            }
        }
        moved => {
            root.dragged(
                (self.mouse-x - root.sx) / (root.box-w * 1px),
                (self.mouse-y - root.sy) / (root.box-h * 1px),
            );
        }
    }
}

// A window-control button for the custom title bar. The icon is drawn as a
// vector shape (not a font glyph) so it stays crisp: kind = "min" | "max" | "close".
component WinButton inherits Rectangle {
    in property <string> kind;
    in property <bool> danger: false;
    callback clicked();
    width: 46px;
    background: ta.has-hover ? (root.danger ? #e23b3b : #2c313b) : transparent;
    property <color> ink: ta.has-hover && root.danger ? #ffffff : #c8ccd4;

    // Minimize: a single horizontal line.
    if root.kind == "min": Rectangle {
        width: 11px;
        height: 1px;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        background: root.ink;
    }
    // Maximize: a square outline.
    if root.kind == "max": Rectangle {
        width: 10px;
        height: 10px;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        border-width: 1px;
        border-color: root.ink;
        background: transparent;
    }
    // Close: an X drawn as two diagonal strokes.
    if root.kind == "close": Path {
        width: 11px;
        height: 11px;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        stroke: root.ink;
        stroke-width: 1.2px;
        viewbox-width: 100;
        viewbox-height: 100;
        MoveTo { x: 0; y: 0; }
        LineTo { x: 100; y: 100; }
        MoveTo { x: 100; y: 0; }
        LineTo { x: 0; y: 100; }
    }

    ta := TouchArea {
        clicked => { root.clicked(); }
    }
}

// A clean segmented control: a rounded track with the active segment as a
// rounded-rect that fills its slice. Used for the mode and the View/Crop toggles.
component SegToggle inherits Rectangle {
    in property <[string]> labels;
    in property <int> selected;
    callback select(int);
    height: 28px;
    border-radius: 8px;
    background: #14171c;
    border-width: 1px;
    border-color: #2c313b;
    HorizontalLayout {
        padding: 3px;
        spacing: 0px;
        for seg[i] in root.labels: Rectangle {
            horizontal-stretch: 1;
            border-radius: 6px;
            background: root.selected == i ? #2dd4bf : (ta.has-hover ? #20242c : transparent);
            animate background { duration: 120ms; }
            Text {
                text: seg;
                horizontal-alignment: center;
                vertical-alignment: center;
                font-size: 12.5px;
                font-weight: 600;
                color: root.selected == i ? #08110f : #9aa3b2;
            }
            ta := TouchArea { clicked => { root.select(i); } }
        }
    }
}

// A draggable vertical divider between body panels. Emits the horizontal drag
// delta since press; the parent clamps it onto a panel width. (The divider moves
// with the resized panel, so the per-event delta self-converges to track the cursor.)
component Splitter inherits Rectangle {
    callback dragged(length);
    width: 12px;
    background: transparent;
    Rectangle {
        width: 2px;
        height: 56%;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        border-radius: 1px;
        background: sta.has-hover || sta.pressed ? #2dd4bf : #2c313b;
        animate background { duration: 120ms; }
    }
    sta := TouchArea {
        mouse-cursor: ew-resize;
        moved => { root.dragged(self.mouse-x - self.pressed-x); }
    }
}

// A compact popover number editor used by the inline crop toolbar. The
// displayed value is computed by the caller (one-way `value`); typing a number
// and pressing Enter fires `edited(int)` with the value clamped to [min,max].
// Callback-based (not two-way bound to a computed property) to avoid binding
// loops.
component NumberDropdown inherits Rectangle {
    in property <string> label;
    in property <int> value;        // display value (computed by caller, one-way)
    in property <int> minimum: 0;
    in property <int> maximum: 100000;
    callback edited(int);           // fires with the new clamped value
    property <bool> open: false;
    width: 66px; height: 24px; border-radius: 6px;
    background: #16181d; border-width: 1px; border-color: #343b46;
    HorizontalLayout {
        padding-left: 6px; padding-right: 6px;
        Text { text: root.label + " " + root.value; color: #e6e9ef; font-size: 10px; vertical-alignment: center; }
    }
    ta := TouchArea { clicked => { root.open = !root.open; } }
    if root.open : Rectangle {
        y: parent.height + 3px; width: 92px; height: 30px;
        background: #20242c; border-radius: 6px; border-width: 1px; border-color: #343b46;
        LineEdit {
            width: 84px; x: 4px; y: 3px;
            text: root.value;
            input-type: number;
            accepted(t) => {
                root.edited(Math.clamp(t.to-float(), root.minimum, root.maximum));
                root.open = false;
            }
        }
    }
}

// A thin 0..1 slider used for the video scrubber and volume. Reports the new
// fraction via `changed` on click or drag.
component Scrubber inherits Rectangle {
    in property <float> value;     // 0..1
    callback changed(float);
    min-height: 18px;
    max-height: 18px;
    horizontal-stretch: 1;
    Rectangle {
        y: parent.height / 2 - 3px;
        height: 6px;
        border-radius: 3px;
        background: #2c313b;
        Rectangle {
            x: 0;
            width: parent.width * Math.clamp(root.value, 0, 1);
            height: parent.height;
            border-radius: 3px;
            background: #2dd4bf;
        }
    }
    Rectangle {
        width: 12px;
        height: 12px;
        border-radius: 6px;
        background: sta.has-hover || sta.pressed ? #e6fffb : white;
        border-width: 2px;
        border-color: #2dd4bf;
        y: parent.height / 2 - 6px;
        x: (root.width - 12px) * Math.clamp(root.value, 0, 1);
    }
    sta := TouchArea {
        function emit(mx: length) { root.changed(Math.clamp(mx / root.width, 0, 1)); }
        moved => { sta.emit(sta.mouse-x); }
        clicked => { sta.emit(sta.mouse-x); }
    }
}

// Labelled slider for the inspector: value ranges over [min, max] and the
// current value is shown on the right. `changed` fires live during a drag.
component InspSlider inherits Rectangle {
    in property <string> label;
    in property <float> min: 0;
    in property <float> max: 100;
    in property <string> suffix: "";
    in-out property <float> value: 0;
    callback changed();
    height: 38px;
    property <float> frac: (root.max - root.min) > 0
        ? Math.clamp((root.value - root.min) / (root.max - root.min), 0, 1) : 0;
    VerticalLayout {
        spacing: 5px;
        HorizontalLayout {
            Text { text: root.label; color: #8b95a6; font-size: 9.5px; font-weight: 600; }
            Rectangle { horizontal-stretch: 1; }
            Text { text: Math.round(root.value) + root.suffix; color: #cfd6e2; font-size: 9.5px; font-weight: 600; }
        }
        Rectangle {
            height: 12px;
            track := Rectangle {
                y: parent.height / 2 - 3px;
                height: 6px;
                border-radius: 3px;
                background: #2c313b;
                Rectangle {
                    x: 0; width: parent.width * root.frac; height: parent.height;
                    border-radius: 3px;
                    background: @linear-gradient(90deg, #3f7df5 0%, #2dd4bf 100%);
                }
            }
            knob := Rectangle {
                width: 12px; height: 12px; border-radius: 6px;
                background: kta.has-hover || kta.pressed ? #e6fffb : white;
                border-width: 2px; border-color: #2dd4bf;
                y: parent.height / 2 - 6px;
                x: (parent.width - 12px) * root.frac;
            }
            kta := TouchArea {
                function emit(mx: length) {
                    root.value = root.min + Math.clamp(mx / self.width, 0, 1) * (root.max - root.min);
                    root.changed();
                }
                moved => { kta.emit(kta.mouse-x); }
                clicked => { kta.emit(kta.mouse-x); }
            }
        }
    }
}

export component AppWindow inherits Window {
    title: "Kuvatin";
    icon: @image-url("../assets/kuvatin-icon.png");
    no-frame: true;
    preferred-width: 1320px;
    preferred-height: 840px;
    min-width: 860px;
    min-height: 560px;
    background: #16181d;

    in property <[FileRow]> files;
    in property <[string]> preset-names;
    in property <bool> running: false;
    in property <float> progress: 0.0;
    in-out property <int> current-preset: 0;
    in-out property <string> format: "webp";
    in-out property <int> quality: 80;
    // PNG optimization mode: 0 = Normal, 1 = Optimize (lossless), 2 = Compress (lossy).
    in-out property <int> png-mode: 0;
    in-out property <string> preset-name;
    // 0 = Images, 1 = Videos. Video mode is a placeholder until the GStreamer plan.
    in-out property <int> app-mode: 0;
    // Adjustable side-panel widths (drag the splitters between cards). The viewer
    // takes the remaining space.
    in-out property <length> files-w: 280px;
    in-out property <length> settings-w: 340px;
    // Video mode: adjustable media-bin and inspector widths (draggable splitters).
    in-out property <length> video-bin-w: 186px;
    in-out property <length> video-insp-w: 238px;

    // Video mode state (set from Rust) and actions.
    in property <image> video-frame;
    in-out property <bool> video-playing: false;
    in property <float> video-position: 0.0;        // 0..1 along the clip
    in property <string> video-time: "0:00 / 0:00";
    in-out property <float> video-volume: 1.0;       // 0..1
    in property <[VideoAsset]> video-clips;
    in-out property <int> video-selected: -1;
    callback video-open();
    callback video-select(int);
    callback video-playpause();
    callback video-seek(float);            // fraction 0..1
    callback video-volume-changed(float);  // 0..1

    // Timeline editor.
    in property <[TimelineClip]> timeline-clips;
    in property <[string]> timeline-track-labels;  // one per track, top row first
    in property <float> timeline-pps: 14.0;   // pixels per second (zoom)
    in-out property <length> tl-scroll: 0px;  // horizontal scroll offset of the lane
    in property <float> playhead: 0.0;        // seconds
    in property <float> timeline-duration: 0.0; // seconds (for the ruler end)
    in property <string> inspector-name: "";  // selected clip name (or empty)
    // Selected clip transform for the inspector (set from Rust on select).
    in-out property <float> insp-posx: 0;      // px within the canvas
    in-out property <float> insp-posy: 0;      // px
    in-out property <float> insp-scale: 100;   // percent of the canvas size
    in-out property <float> insp-alpha: 100;   // opacity percent
    in-out property <float> insp-volume: 100;  // percent
    in property <bool> insp-has-audio: true;   // hide volume for stills
    // Selected clip's aspect-fit size in canvas px (for the preview bounding box).
    in property <float> sel-fit-w: 1280;
    in property <float> sel-fit-h: 720;
    // Timeline drag state (drives the "new track" drop indicator).
    in-out property <bool> clip-dragging: false;
    in-out property <int> clip-drag-target-row: 0;
    // File import progress (a worker discovers files off the UI thread).
    in property <bool> importing: false;
    in property <int> import-done: 0;
    in property <int> import-total: 0;
    callback inspector-changed();              // any inspector slider moved
    callback timeline-select(int);            // clip index
    callback timeline-seek-time(float);       // seconds (from ruler/lane click)
    callback timeline-clip-dropped(int, float, int); // clip index, delta seconds (slide), delta rows (track change)
    callback timeline-clip-trimmed(int, int, float); // clip index, edge (-1 left / +1 right), delta seconds
    callback track-reordered(int, int);              // drag a track header: from row → to row

    // Crop editor state. The crop rectangle is stored in NORMALIZED coordinates
    // (0..1) relative to the displayed image, so the preview size is irrelevant —
    // Rust maps normalized → absolute pixels using the original image dimensions.
    in-out property <bool> cropping: false;
    in property <float> crop-box-w: 400;   // preview box size in px (matches image aspect)
    in property <float> crop-box-h: 300;
    in-out property <float> crop-x: 0;
    in-out property <float> crop-y: 0;
    in-out property <float> crop-w: 1;
    in-out property <float> crop-h: 1;
    in-out property <bool> aspect-lock: false;
    // Original (full-resolution) dimensions of the image being cropped, so the
    // numeric X/Y/W/H fields can be shown and edited in absolute pixels.
    in property <int> crop-img-w;
    in property <int> crop-img-h;

    // Output-resolution override (Settings panel). 0 means "use preset size".
    in-out property <int> res-w: 0;
    in-out property <int> res-h: 0;
    in-out property <bool> res-lock: true;

    // Default suffix appended to output file names (e.g. "photo-kuvatin.webp").
    // Seeds the Save dialog name for one file and is applied to every file when
    // converting a batch into a chosen folder. Saved with the preset.
    in-out property <string> suffix: "-kuvatin";
    // When set, outputs go into a subfolder named after the suffix.
    in-out property <bool> save-subfolder: false;

    // Custom window-frame controls (frameless window; wired to Win32 in gui.rs).
    callback win-minimize();
    callback win-maximize();
    callback win-close();
    callback win-drag();

    callback add-files();
    callback clear-files();
    callback preset-changed(int);
    callback convert();
    callback save-preset(string);
    callback delete-preset();
    callback apply-crop();

    // Central image viewer.
    in-out property <int> selected-index: -1;
    in property <image> viewer-image;
    callback select-file(int);

    VerticalLayout {
        padding: 0px;
        spacing: 0px;

        // Custom title bar ----------------------------------------------
        Rectangle {
            min-height: 36px;
            max-height: 36px;
            background: #16181d;

            // Dragging is handled natively via WM_NCHITTEST (HTCAPTION) in the
            // Win32 subclass; the window buttons stay clickable (HTCLIENT).
            HorizontalLayout {
                padding-left: 12px;
                spacing: 8px;

                Image {
                    source: @image-url("../assets/kuvatin-icon.svg");
                    width: 20px;
                    height: 20px;
                    y: (parent.height - self.height) / 2;
                }
                Text {
                    text: "Kuvatin";
                    color: #f2f4f8;
                    font-size: 14px;
                    font-weight: 800;
                    vertical-alignment: center;
                }

                Rectangle { horizontal-stretch: 1; }

                WinButton { kind: "min"; clicked => { root.win-minimize(); } }
                WinButton { kind: "max"; clicked => { root.win-maximize(); } }
                WinButton { kind: "close"; danger: true; clicked => { root.win-close(); } }
            }
        }

        // Mode toggle bar — below the titlebar (client area) so clicks register.
        // In the titlebar, the native drag hit-test (HTCAPTION) swallows clicks.
        Rectangle {
            height: 42px;
            background: #16181d;
            SegToggle {
                width: 184px;
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;
                labels: ["Images", "Videos"];
                selected: root.app-mode;
                select(i) => { root.app-mode = i; }
            }
        }

        // Body -----------------------------------------------------------
        if root.app-mode == 0: HorizontalLayout {
            padding: 16px;
            spacing: 0px;

            // Files card
            Card {
                width: root.files-w;
                clip: true;
                VerticalLayout {
                    padding: 16px;
                    spacing: 12px;

                    Text {
                        text: "Files";
                        color: #f2f4f8;
                        font-size: 15px;
                        font-weight: 700;
                    }

                    // list / empty-state
                    Rectangle {
                        vertical-stretch: 1;
                        background: #181b21;
                        border-radius: 8px;
                        border-width: 1px;
                        border-color: #2c313b;

                        // empty-state
                        if root.files.length == 0: VerticalLayout {
                            alignment: center;
                            spacing: 16px;

                            // Minimalist line-art image glyph in the app accent:
                            // a rounded frame with a sun and a mountain.
                            HorizontalLayout {
                                alignment: center;
                                Rectangle {
                                    width: 64px;
                                    height: 64px;
                                    border-radius: 14px;
                                    border-width: 2px;
                                    border-color: #2dd4bf;
                                    background: transparent;
                                    clip: true;
                                    // sun
                                    Rectangle {
                                        width: 13px;
                                        height: 13px;
                                        border-radius: 7px;
                                        x: 14px;
                                        y: 14px;
                                        background: #2dd4bf;
                                    }
                                    // mountains rising from the bottom edge
                                    Path {
                                        width: 64px;
                                        height: 64px;
                                        viewbox-width: 64;
                                        viewbox-height: 64;
                                        fill: #2dd4bf;
                                        commands: "M0 64 L24 36 L37 49 L48 32 L64 52 L64 64 Z";
                                    }
                                }
                            }
                            Text {
                                text: "Drop images here\nor click Add files…";
                                color: #9aa3b2;
                                font-size: 13px;
                                horizontal-alignment: center;
                            }
                        }

                        // populated list
                        if root.files.length > 0: ListView {
                            for row[i] in root.files: Rectangle {
                                height: 44px;
                                background: root.selected-index == i
                                    ? #2dd4bf18
                                    : (row-ta.has-hover ? #262b34 : (Math.mod(i, 2) == 0 ? transparent : #1c2027));
                                row-ta := TouchArea {
                                    clicked => { root.select-file(i); }
                                }
                                HorizontalLayout {
                                    padding-left: 12px;
                                    padding-right: 14px;
                                    spacing: 10px;

                                    // thumbnail with a subtle rounded backing
                                    Rectangle {
                                        width: 40px;
                                        height: 40px;
                                        y: (parent.height - self.height) / 2;
                                        border-radius: 6px;
                                        background: #181b21;
                                        border-width: 1px;
                                        border-color: #2c313b;
                                        clip: true;
                                        Image {
                                            source: row.thumb;
                                            width: 40px;
                                            height: 40px;
                                            image-fit: contain;
                                        }
                                    }

                                    Text {
                                        text: row.name;
                                        color: #f2f4f8;
                                        font-size: 13px;
                                        vertical-alignment: center;
                                        horizontal-stretch: 1;
                                        overflow: elide;
                                    }
                                    Text {
                                        text: row.dims;
                                        color: #9aa3b2;
                                        font-size: 11px;
                                        vertical-alignment: center;
                                    }
                                    Rectangle {
                                        visible: row.cropped;
                                        height: 16px; border-radius: 999px; background: #2dd4bf;
                                        y: (parent.height - self.height) / 2;
                                        HorizontalLayout {
                                            padding-left: 6px; padding-right: 6px;
                                            Text { text: "crop"; color: #08110f; font-size: 9px; font-weight: 700; vertical-alignment: center; }
                                        }
                                    }
                                    Text {
                                        text: row.status;
                                        color: row.status == "done"
                                            ? #2dd4bf
                                            : (row.status == "error" ? #f87171 : #9aa3b2);
                                        font-size: 12px;
                                        vertical-alignment: center;
                                    }
                                }
                            }
                        }
                    }

                    HorizontalLayout {
                        spacing: 10px;
                        SecondaryButton {
                            text: "Add files…";
                            clicked => { root.add-files(); }
                        }
                        SecondaryButton {
                            text: "Clear";
                            clicked => { root.clear-files(); }
                        }
                        Rectangle { horizontal-stretch: 1; }
                    }
                }
            }

            // Lower bound = the Files list's content width; upper bound keeps the
            // viewer at >= its min so nothing is squeezed off-screen.
            Splitter { dragged(dx) => {
                root.files-w = Math.clamp(root.files-w + dx, 200px, root.width - root.settings-w - 296px);
            } }

            // Viewer card
            Card {
                min-width: 240px;
                horizontal-stretch: 1;
                clip: true;
                VerticalLayout {
                    padding: 12px; spacing: 8px;

                    Text { text: "Preview"; color: #f2f4f8; font-size: 15px; font-weight: 700; }

                    // Toolbar: View/Crop toggle + (when cropping) numeric crop
                    // controls and the aspect-lock button.
                    HorizontalLayout {
                        height: 28px;
                        spacing: 8px;

                        // View / Crop segmented toggle. Selecting Crop enters crop
                        // mode; selecting View applies the current crop then exits.
                        SegToggle {
                            width: 132px;
                            labels: ["View", "Crop"];
                            selected: root.cropping ? 1 : 0;
                            select(i) => {
                                if (i == 0) {
                                    if (root.cropping) { root.apply-crop(); }
                                    root.cropping = false;
                                } else {
                                    root.cropping = true;
                                }
                            }
                        }

                        Rectangle { horizontal-stretch: 1; }

                        if root.cropping : HorizontalLayout {
                            spacing: 6px;
                            NumberDropdown { label: "X"; value: round(root.crop-x * root.crop-img-w); maximum: root.crop-img-w - 1;
                                edited(v) => { root.crop-x = Math.clamp(v / Math.max(root.crop-img-w, 1), 0.0, 1.0 - root.crop-w); } }
                            NumberDropdown { label: "Y"; value: round(root.crop-y * root.crop-img-h); maximum: root.crop-img-h - 1;
                                edited(v) => { root.crop-y = Math.clamp(v / Math.max(root.crop-img-h, 1), 0.0, 1.0 - root.crop-h); } }
                            NumberDropdown { label: "W"; value: round(root.crop-w * root.crop-img-w); minimum: 1; maximum: root.crop-img-w;
                                edited(v) => { root.crop-w = Math.clamp(v / Math.max(root.crop-img-w, 1), 0.0, 1.0 - root.crop-x); } }
                            NumberDropdown { label: "H"; value: round(root.crop-h * root.crop-img-h); minimum: 1; maximum: root.crop-img-h;
                                edited(v) => { root.crop-h = Math.clamp(v / Math.max(root.crop-img-h, 1), 0.0, 1.0 - root.crop-y); } }
                            Rectangle {
                                width: 26px; border-radius: 6px;
                                background: root.aspect-lock ? #2dd4bf : #16181d;
                                border-width: 1px; border-color: #343b46;
                                Text { text: "🔒"; font-size: 11px; horizontal-alignment: center; vertical-alignment: center; }
                                TouchArea { clicked => { root.aspect-lock = !root.aspect-lock; } }
                            }
                        }
                    }

                    // Crop surface: hosts the preview and the inline crop editor.
                    // The crop math (ported verbatim from the modal) works in the
                    // crop-box-w/h coordinate system, so the crop UI is rendered as
                    // a CENTERED region of exactly crop-box-w × crop-box-h px — the
                    // same coordinate system the modal uses.
                    crop-surface := Rectangle {
                        vertical-stretch: 1;
                        background: #0b0d11;
                        border-radius: 8px;
                        border-width: 1.5px;
                        border-color: #2dd4bf;
                        clip: true;

                        // Minimum normalized rect size, so a rectangle can't collapse.
                        property <float> min-n: 0.03;

                        // Drag bookkeeping for moving the whole rectangle.
                        property <length> move-sx;
                        property <length> move-sy;
                        property <float> move-x0;
                        property <float> move-y0;

                        // Edge values captured at the start of a corner drag.
                        property <float> edge-l;
                        property <float> edge-t;
                        property <float> edge-r;
                        property <float> edge-b;
                        // Aspect ratio (w:h in box pixels) captured for aspect-lock resizing.
                        property <float> edge-ratio;

                        function begin-corner() {
                            self.edge-l = root.crop-x;
                            self.edge-t = root.crop-y;
                            self.edge-r = root.crop-x + root.crop-w;
                            self.edge-b = root.crop-y + root.crop-h;
                            self.edge-ratio = (root.crop-w * root.crop-box-w) / (root.crop-h * root.crop-box-h);
                        }

                        // Apply a corner drag. sgx/sgy pick which edges move (-1 left/top, +1 right/bottom).
                        function corner(sgx: float, sgy: float, dx: float, dy: float) {
                            // Horizontal edge.
                            if (sgx < 0) {
                                self.edge-l = Math.clamp(self.edge-l + dx, 0, self.edge-r - self.min-n);
                            } else {
                                self.edge-r = Math.clamp(self.edge-r + dx, self.edge-l + self.min-n, 1);
                            }
                            // Vertical edge.
                            if (sgy < 0) {
                                self.edge-t = Math.clamp(self.edge-t + dy, 0, self.edge-b - self.min-n);
                            } else {
                                self.edge-b = Math.clamp(self.edge-b + dy, self.edge-t + self.min-n, 1);
                            }

                            root.crop-x = self.edge-l;
                            root.crop-y = self.edge-t;
                            root.crop-w = self.edge-r - self.edge-l;
                            root.crop-h = self.edge-b - self.edge-t;

                            if (root.aspect-lock && self.edge-ratio > 0) {
                                // Recompute height from width to preserve the on-screen aspect:
                                // crop-w*box-w : crop-h*box-h == edge-ratio. Solve for crop-h.
                                root.crop-h = (root.crop-w * root.crop-box-w) / (self.edge-ratio * root.crop-box-h);
                                // Grow/shrink from the anchored corner (the edge that did NOT move).
                                if (sgy < 0) {
                                    root.crop-y = self.edge-b - root.crop-h;
                                }
                                // Clamp the derived height into bounds; if it overflows, fall back
                                // to a height that fits and re-anchor.
                                if (root.crop-y < 0) {
                                    root.crop-y = 0;
                                    root.crop-h = self.edge-b;
                                }
                                if (root.crop-y + root.crop-h > 1) {
                                    root.crop-h = 1 - root.crop-y;
                                }
                            }
                        }

                        if root.selected-index < 0: Text {
                            text: "Select a file to preview";
                            color: #6b7585; font-size: 13px;
                            horizontal-alignment: center; vertical-alignment: center;
                        }

                        // Plain preview when not cropping.
                        if root.selected-index >= 0 && !root.cropping: Image {
                            source: root.viewer-image;
                            image-fit: contain;
                            width: 100%; height: 100%;
                        }

                        // Inline crop editor: a centered crop-box-w × crop-box-h
                        // region holding the image, with the modal's dim strips,
                        // crop rectangle, move handle and four corner handles —
                        // ported verbatim (parent-overlay → crop-surface).
                        if root.selected-index >= 0 && root.cropping: cbox := Rectangle {
                            x: (parent.width - self.width) / 2;
                            y: (parent.height - self.height) / 2;
                            width: root.crop-box-w * 1px;
                            height: root.crop-box-h * 1px;
                            border-radius: 6px;
                            clip: true;

                            Image {
                                source: root.viewer-image;
                                width: 100%;
                                height: 100%;
                                image-fit: fill;
                            }

                            // Dim overlay outside the crop selection (four strips).
                            Rectangle { x: 0; y: 0; width: parent.width; height: root.crop-y * parent.height; background: #00000099; }
                            Rectangle { x: 0; y: (root.crop-y + root.crop-h) * parent.height; width: parent.width; height: parent.height - (root.crop-y + root.crop-h) * parent.height; background: #00000099; }
                            Rectangle { x: 0; y: root.crop-y * parent.height; width: root.crop-x * parent.width; height: root.crop-h * parent.height; background: #00000099; }
                            Rectangle { x: (root.crop-x + root.crop-w) * parent.width; y: root.crop-y * parent.height; width: parent.width - (root.crop-x + root.crop-w) * parent.width; height: root.crop-h * parent.height; background: #00000099; }

                            // The crop rectangle border + move handle.
                            crect := Rectangle {
                                x: root.crop-x * parent.width;
                                y: root.crop-y * parent.height;
                                width: root.crop-w * parent.width;
                                height: root.crop-h * parent.height;
                                border-width: 2px;
                                border-color: #2dd4bf;

                                cmove-ta := TouchArea {
                                    mouse-cursor: move;
                                    pointer-event(ev) => {
                                        if (ev.kind == PointerEventKind.down) {
                                            crop-surface.move-sx = self.mouse-x;
                                            crop-surface.move-sy = self.mouse-y;
                                            crop-surface.move-x0 = root.crop-x;
                                            crop-surface.move-y0 = root.crop-y;
                                        }
                                    }
                                    moved => {
                                        root.crop-x = Math.clamp(
                                            crop-surface.move-x0 + (self.mouse-x - crop-surface.move-sx) / (root.crop-box-w * 1px),
                                            0, 1 - root.crop-w);
                                        root.crop-y = Math.clamp(
                                            crop-surface.move-y0 + (self.mouse-y - crop-surface.move-sy) / (root.crop-box-h * 1px),
                                            0, 1 - root.crop-h);
                                    }
                                }
                            }

                            // Four corner resize handles. Inset so the full handle
                            // stays visible at each corner. Each reports normalized
                            // drag deltas.
                            CropHandle {
                                x: root.crop-x * cbox.width;
                                y: root.crop-y * cbox.height;
                                box-w: root.crop-box-w; box-h: root.crop-box-h;
                                sign-x: -1; sign-y: -1;
                                pressed => { crop-surface.begin-corner(); }
                                dragged(dx, dy) => { crop-surface.corner(-1, -1, dx, dy); }
                            }
                            CropHandle {
                                x: (root.crop-x + root.crop-w) * cbox.width - self.width;
                                y: root.crop-y * cbox.height;
                                box-w: root.crop-box-w; box-h: root.crop-box-h;
                                sign-x: 1; sign-y: -1;
                                pressed => { crop-surface.begin-corner(); }
                                dragged(dx, dy) => { crop-surface.corner(1, -1, dx, dy); }
                            }
                            CropHandle {
                                x: root.crop-x * cbox.width;
                                y: (root.crop-y + root.crop-h) * cbox.height - self.height;
                                box-w: root.crop-box-w; box-h: root.crop-box-h;
                                sign-x: -1; sign-y: 1;
                                pressed => { crop-surface.begin-corner(); }
                                dragged(dx, dy) => { crop-surface.corner(-1, 1, dx, dy); }
                            }
                            CropHandle {
                                x: (root.crop-x + root.crop-w) * cbox.width - self.width;
                                y: (root.crop-y + root.crop-h) * cbox.height - self.height;
                                box-w: root.crop-box-w; box-h: root.crop-box-h;
                                sign-x: 1; sign-y: 1;
                                pressed => { crop-surface.begin-corner(); }
                                dragged(dx, dy) => { crop-surface.corner(1, 1, dx, dy); }
                            }
                        }
                    }
                }
            }

            // Lower bound = the Settings form's content width (the widest row is
            // the "Save to a subfolder…" label); upper bound keeps the viewer alive.
            Splitter { dragged(dx) => {
                root.settings-w = Math.clamp(root.settings-w - dx, 330px, root.width - root.files-w - 296px);
            } }

            // Settings card
            Card {
                width: root.settings-w;
                clip: true;
                VerticalLayout {
                    padding: 16px;
                    spacing: 14px;

                    Text {
                        text: "Settings";
                        color: #f2f4f8;
                        font-size: 15px;
                        font-weight: 700;
                    }

                    VerticalLayout {
                        spacing: 6px;
                        FieldLabel { text: "PRESET"; }
                        ComboBox {
                            model: root.preset-names;
                            current-index <=> root.current-preset;
                            selected => { root.preset-changed(self.current-index); }
                        }
                        HorizontalLayout {
                            spacing: 8px;
                            LineEdit {
                                placeholder-text: "Preset name";
                                text <=> root.preset-name;
                                horizontal-stretch: 1;
                            }
                            SecondaryButton {
                                text: "Save";
                                min-width: 72px;
                                clicked => { root.save-preset(root.preset-name); }
                            }
                            SecondaryButton {
                                text: "Delete";
                                min-width: 72px;
                                clicked => { root.delete-preset(); }
                            }
                        }
                    }

                    VerticalLayout {
                        spacing: 6px;
                        FieldLabel { text: "FORMAT"; }
                        ComboBox {
                            model: ["png", "jpeg", "webp", "bmp", "tiff", "gif"];
                            current-value <=> root.format;
                        }
                    }

                    // PNG size optimization (only relevant for PNG output).
                    if root.format == "png": VerticalLayout {
                        spacing: 6px;
                        FieldLabel { text: "PNG OPTIMIZATION"; }
                        ComboBox {
                            model: ["Normal", "Optimize (lossless)", "Compress (lossy · uses quality)"];
                            current-index <=> root.png-mode;
                        }
                    }

                    // Quality only applies to lossy outputs: JPEG, WebP, and PNG
                    // in "Compress (lossy)" mode (png-mode == 2).
                    if root.format == "jpeg" || root.format == "webp"
                        || (root.format == "png" && root.png-mode == 2): VerticalLayout {
                        spacing: 6px;
                        FieldLabel { text: "QUALITY (\{root.quality})"; }
                        QualitySlider {
                            value <=> root.quality;
                        }
                    }

                    VerticalLayout {
                        spacing: 6px;
                        FieldLabel { text: "RESOLUTION (px)"; }
                        HorizontalLayout {
                            spacing: 10px;
                            VerticalLayout {
                                spacing: 2px;
                                FieldLabel { text: "WIDTH"; }
                                SpinBox {
                                    minimum: 0;
                                    maximum: 20000;
                                    value <=> root.res-w;
                                }
                            }
                            VerticalLayout {
                                spacing: 2px;
                                FieldLabel { text: "HEIGHT"; }
                                SpinBox {
                                    minimum: 0;
                                    maximum: 20000;
                                    value <=> root.res-h;
                                }
                            }
                        }
                        HorizontalLayout {
                            spacing: 8px;
                            CheckBox {
                                text: "Keep aspect";
                                checked <=> root.res-lock;
                            }
                            Rectangle { horizontal-stretch: 1; }
                        }
                        Text {
                            text: "0 = keep preset size";
                            color: #9aa3b2;
                            font-size: 11px;
                        }
                    }

                    VerticalLayout {
                        spacing: 6px;
                        FieldLabel { text: "FILE NAME SUFFIX"; }
                        LineEdit {
                            placeholder-text: "e.g. -kuvatin";
                            text <=> root.suffix;
                        }
                        CheckBox {
                            text: "Save to a subfolder (named after the suffix)";
                            checked <=> root.save-subfolder;
                        }
                    }

                    // spacer pushes the action block to the bottom
                    Rectangle { vertical-stretch: 1; }

                    if root.running: ProgressIndicator {
                        height: 6px;
                        progress: root.progress;
                    }

                    Rectangle {
                        height: 42px;
                        border-radius: 8px;
                        background: root.running
                            ? #1d6b62
                            : (convert-ta.pressed
                                ? #14b8a6
                                : (convert-ta.has-hover ? #14b8a6 : #2dd4bf));
                        Text {
                            text: root.running ? "Converting…" : "Convert";
                            color: root.running ? #9aa3b2 : #08110f;
                            font-size: 14px;
                            font-weight: 700;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                        convert-ta := TouchArea {
                            enabled: !root.running;
                            clicked => { root.convert(); }
                        }
                    }
                }
            }
        }
        if root.app-mode == 1: VerticalLayout {
            spacing: 0px;

            // ===== Main row: media bin · composited viewer + transport · inspector =====
            HorizontalLayout {
                vertical-stretch: 1;
                padding: 12px;
                // Zero spacing: the 12px Splitter is the whole inter-panel gap
                // (matches the image view's thin handles).
                spacing: 0px;

                // Media bin
                Card {
                    width: root.video-bin-w;
                    clip: true;
                    VerticalLayout {
                        padding: 11px;
                        spacing: 7px;
                        Text { text: "MEDIA"; color: #8b95a6; font-size: 9.5px; font-weight: 700; letter-spacing: 1px; }
                        Rectangle {
                            vertical-stretch: 1;
                            if root.video-clips.length == 0 : Text {
                                text: "Open a video or image\nto add it here";
                                color: #6b7585; font-size: 11px;
                                horizontal-alignment: center; vertical-alignment: center;
                            }
                            if root.video-clips.length > 0 : ListView {
                                for asset[i] in root.video-clips : Rectangle {
                                    height: 33px; border-radius: 7px;
                                    background: root.video-selected == i ? #2dd4bf18 : (asset-ta.has-hover ? #262b34 : transparent);
                                    asset-ta := TouchArea { clicked => { root.video-select(i); } }
                                    HorizontalLayout {
                                        padding-left: 8px; padding-right: 8px; spacing: 8px;
                                        Rectangle {
                                            width: 32px; height: 21px; y: (parent.height - self.height) / 2;
                                            border-radius: 4px; background: #2c313b; clip: true;
                                            border-width: 1px; border-color: #ffffff14;
                                            Image { source: asset.thumb; image-fit: cover; width: 100%; height: 100%; }
                                        }
                                        Text { text: asset.name; color: #cdd3dc; font-size: 11px; vertical-alignment: center; overflow: elide; horizontal-stretch: 1; }
                                    }
                                }
                            }
                        }
                        SecondaryButton { text: "Open media…"; clicked => { root.video-open(); } }
                    }
                }

                Splitter {
                    dragged(dx) => {
                        root.video-bin-w = Math.clamp(root.video-bin-w + dx, 150px, root.width - root.video-insp-w - 320px);
                    }
                }

                // Composited viewer + transport
                VerticalLayout {
                    horizontal-stretch: 1;
                    spacing: 8px;
                    Rectangle {
                        vertical-stretch: 1;
                        background: #000;
                        border-radius: 9px; border-width: 1px; border-color: #2c313b;
                        clip: true;
                        if root.video-frame.width > 0 : Image { source: root.video-frame; image-fit: contain; width: 100%; height: 100%; }
                        if root.video-frame.width <= 0 : Text {
                            text: "Add a clip to the timeline to preview";
                            color: #6b7585; font-size: 13px;
                            horizontal-alignment: center; vertical-alignment: center;
                        }

                        // Bounding box: move/resize the selected clip on the canvas.
                        // The TouchArea fills the (fixed) viewer for stable drag
                        // deltas; the visible box is derived from insp-* (reactive).
                        if root.inspector-name != "" && root.video-frame.width > 0 : edit-layer := Rectangle {
                            // canvas 1280x720 → viewer mapping under image-fit: contain
                            property <bool> hlim: (self.width / self.height) > (1280.0 / 720.0);
                            property <length> disp-w: hlim ? self.height * 1280 / 720 : self.width;
                            property <length> off-x: (self.width - disp-w) / 2;
                            property <length> off-y: (self.height - (hlim ? self.height : self.width * 720 / 1280)) / 2;
                            property <length> ppc: disp-w / 1280;      // viewer px per canvas px
                            property <float> rw: (root.insp-scale / 100) * root.sel-fit-w;   // canvas px
                            property <float> rh: (root.insp-scale / 100) * root.sel-fit-h;
                            property <length> bx: off-x + root.insp-posx * ppc;
                            property <length> by: off-y + root.insp-posy * ppc;
                            property <length> bw: rw * ppc;
                            property <length> bh: rh * ppc;

                            Rectangle {
                                x: edit-layer.bx; y: edit-layer.by;
                                width: edit-layer.bw; height: edit-layer.bh;
                                background: #2dd4bf10;
                                border-width: 1.5px; border-color: #2dd4bf;
                                Rectangle { x: -4px; y: -4px; width: 9px; height: 9px; background: white; border-width: 1px; border-color: #2dd4bf; }
                                Rectangle { x: parent.width - 5px; y: -4px; width: 9px; height: 9px; background: white; border-width: 1px; border-color: #2dd4bf; }
                                Rectangle { x: -4px; y: parent.height - 5px; width: 9px; height: 9px; background: white; border-width: 1px; border-color: #2dd4bf; }
                                Rectangle { x: parent.width - 5px; y: parent.height - 5px; width: 9px; height: 9px; background: white; border-width: 1px; border-color: #2dd4bf; }
                            }

                            eta := TouchArea {
                                property <int> mode: 0;      // 0 none, 1 move, 2 resize
                                property <float> cen-x: 0;   // canvas center (resize anchor)
                                property <float> cen-y: 0;
                                property <float> b-posx: 0;
                                property <float> b-posy: 0;
                                mouse-cursor: eta.mode == 2 ? MouseCursor.nwse-resize : MouseCursor.move;
                                pointer-event(ev) => {
                                    if (ev.kind == PointerEventKind.down) {
                                        eta.b-posx = root.insp-posx;
                                        eta.b-posy = root.insp-posy;
                                        eta.cen-x = root.insp-posx + edit-layer.rw / 2;
                                        eta.cen-y = root.insp-posy + edit-layer.rh / 2;
                                        if (Math.max(Math.abs(self.pressed-x - edit-layer.bx), Math.abs(self.pressed-y - edit-layer.by)) < 16px
                                            || Math.max(Math.abs(self.pressed-x - (edit-layer.bx + edit-layer.bw)), Math.abs(self.pressed-y - edit-layer.by)) < 16px
                                            || Math.max(Math.abs(self.pressed-x - edit-layer.bx), Math.abs(self.pressed-y - (edit-layer.by + edit-layer.bh))) < 16px
                                            || Math.max(Math.abs(self.pressed-x - (edit-layer.bx + edit-layer.bw)), Math.abs(self.pressed-y - (edit-layer.by + edit-layer.bh))) < 16px) {
                                            eta.mode = 2;
                                        } else if (self.pressed-x >= edit-layer.bx && self.pressed-x <= edit-layer.bx + edit-layer.bw
                                            && self.pressed-y >= edit-layer.by && self.pressed-y <= edit-layer.by + edit-layer.bh) {
                                            eta.mode = 1;
                                        } else {
                                            eta.mode = 0;
                                        }
                                    }
                                    if (ev.kind == PointerEventKind.up) { eta.mode = 0; }
                                }
                                moved => {
                                    if (eta.mode == 1) {
                                        root.insp-posx = eta.b-posx + (self.mouse-x - self.pressed-x) / edit-layer.ppc;
                                        root.insp-posy = eta.b-posy + (self.mouse-y - self.pressed-y) / edit-layer.ppc;
                                        root.inspector-changed();
                                    } else if (eta.mode == 2) {
                                        root.insp-scale = Math.clamp(Math.abs((self.mouse-x - edit-layer.off-x) / edit-layer.ppc - eta.cen-x) * 2 / root.sel-fit-w * 100, 10, 100);
                                        root.insp-posx = eta.cen-x - (root.insp-scale / 100) * root.sel-fit-w / 2;
                                        root.insp-posy = eta.cen-y - (root.insp-scale / 100) * root.sel-fit-h / 2;
                                        root.inspector-changed();
                                    }
                                }
                            }
                        }
                    }
                    HorizontalLayout {
                        height: 30px; spacing: 9px;
                        Rectangle {
                            width: 32px; border-radius: 8px;
                            background: pp-ta.has-hover ? #20242c : transparent;
                            Text { text: root.video-playing ? "⏸" : "▶"; color: #e6e9ef; font-size: 14px; horizontal-alignment: center; vertical-alignment: center; }
                            pp-ta := TouchArea { clicked => { root.video-playpause(); } }
                        }
                        Text { text: root.video-time; color: #9aa3b2; font-size: 11px; vertical-alignment: center; }
                        Scrubber { value: root.video-position; changed(f) => { root.video-seek(f); } }
                        Text { text: "🔊"; font-size: 12px; vertical-alignment: center; }
                        Scrubber { width: 70px; value: root.video-volume; changed(f) => { root.video-volume-changed(f); } }
                    }
                }

                Splitter {
                    dragged(dx) => {
                        root.video-insp-w = Math.clamp(root.video-insp-w - dx, 200px, root.width - root.video-bin-w - 320px);
                    }
                }

                // Inspector: edit the selected clip's transform, opacity & volume.
                Card {
                    width: root.video-insp-w;
                    clip: true;
                    VerticalLayout {
                        padding: 11px;
                        spacing: 9px;
                        Text { text: root.inspector-name == "" ? "INSPECTOR" : "LAYER"; color: #8b95a6; font-size: 9.5px; font-weight: 700; letter-spacing: 1px; }
                        if root.inspector-name == "" : Text {
                            text: "Select a clip to edit its\ntransform, opacity & volume";
                            color: #6b7585; font-size: 11px; vertical-alignment: center; horizontal-alignment: center;
                        }
                        if root.inspector-name != "" : Text {
                            text: root.inspector-name; color: #f2f4f8; font-size: 13px; font-weight: 600;
                            overflow: elide;
                        }
                        if root.inspector-name != "" : VerticalLayout {
                            spacing: 6px;
                            InspSlider { label: "Position X"; min: -1280; max: 1280; suffix: "px"; value <=> root.insp-posx; changed => { root.inspector-changed(); } }
                            InspSlider { label: "Position Y"; min: -720; max: 720; suffix: "px"; value <=> root.insp-posy; changed => { root.inspector-changed(); } }
                            InspSlider { label: "Scale"; min: 10; max: 100; suffix: "%"; value <=> root.insp-scale; changed => { root.inspector-changed(); } }
                            InspSlider { label: "Opacity"; min: 0; max: 100; suffix: "%"; value <=> root.insp-alpha; changed => { root.inspector-changed(); } }
                            if root.insp-has-audio : InspSlider { label: "Volume"; min: 0; max: 100; suffix: "%"; value <=> root.insp-volume; changed => { root.inspector-changed(); } }
                        }
                        Rectangle { vertical-stretch: 1; }
                    }
                }
            }

            // ===== Timeline band =====
            Rectangle {
                height: 176px;
                background: #101319;
                border-width: 1px; border-color: #2c313b;
                VerticalLayout {
                    spacing: 0px;

                    // toolbar
                    Rectangle {
                        height: 26px; background: #13161c;
                        HorizontalLayout {
                            padding-left: 11px; padding-right: 11px; spacing: 8px;
                            Text { text: "TIMELINE"; color: #8b95a6; font-size: 9.5px; font-weight: 700; letter-spacing: 1px; vertical-alignment: center; }
                            Rectangle { horizontal-stretch: 1; }
                            Text { text: "drag clips to arrange"; color: #5e6675; font-size: 9px; vertical-alignment: center; }
                        }
                    }

                    // rows: gutter (track headers) + lane area
                    HorizontalLayout {
                        vertical-stretch: 1;

                        VerticalLayout {
                            width: 94px;
                            // Drag a header up/down to reorder tracks.
                            for lbl[t] in root.timeline-track-labels : hdr := Rectangle {
                                height: 30px;
                                background: hta.pressed ? #20242c : #13161c;
                                border-width: 1px; border-color: #181c23;
                                property <length> ddy: 0px;
                                HorizontalLayout {
                                    padding-left: 9px; spacing: 6px;
                                    Text { text: "≡"; color: hta.has-hover ? #8b95a6 : #5e6675; font-size: 11px; vertical-alignment: center; }
                                    Text { text: lbl; color: #8b95a6; font-size: 9px; vertical-alignment: center; overflow: elide; }
                                }
                                hta := TouchArea {
                                    mouse-cursor: ns-resize;
                                    moved => { hdr.ddy = self.mouse-y - self.pressed-y; }
                                    pointer-event(ev) => {
                                        if (ev.kind == PointerEventKind.up) {
                                            if (Math.abs(hdr.ddy / 1px) > 15) {
                                                root.track-reordered(t, Math.clamp(t + Math.round(hdr.ddy / 30px), 0, root.timeline-track-labels.length - 1));
                                            }
                                            hdr.ddy = 0px;
                                        }
                                    }
                                }
                            }
                        }

                        lane := Rectangle {
                            horizontal-stretch: 1;
                            clip: true;
                            background: #0e1116;
                            // Horizontal scroll: content width vs the visible lane.
                            property <length> content-w: (root.timeline-duration * root.timeline-pps) * 1px + 40px;
                            property <length> max-scroll: max(0px, self.content-w - self.width);
                            property <length> scroll: Math.clamp(root.tl-scroll, 0px, self.max-scroll);

                            // row background stripes (fixed; span the visible lane)
                            VerticalLayout {
                                for lbl[t] in root.timeline-track-labels : Rectangle { height: 30px; border-width: 1px; border-color: #181c23; }
                            }

                            // "new track" drop zone, shown while dragging a clip.
                            // Teal-tinted so it's visible against the dark lane; sits
                            // behind the clip blocks so the dragged clip stays on top.
                            if root.clip-dragging : Rectangle {
                                property <bool> active: root.clip-drag-target-row >= root.timeline-track-labels.length;
                                y: root.timeline-track-labels.length * 30px + 3px;
                                x: 4px; width: parent.width - 8px; height: 22px;
                                border-radius: 6px;
                                background: active ? #2dd4bf3a : #14302b;
                                border-width: active ? 2px : 1px;
                                border-color: active ? #2dd4bf : #2dd4bf99;
                                Text {
                                    text: "＋  Drop here for a new track";
                                    color: active ? #ffffff : #5fdccb;
                                    font-size: 10px; font-weight: 700;
                                    horizontal-alignment: center; vertical-alignment: center;
                                }
                            }

                            // clip blocks. The wrapper `blk` keeps the clip's MODEL
                            // geometry (fixed during a drag) so the hit-areas sit in a
                            // stable frame; `vis` is the visual block that moves/resizes
                            // live from the pointer delta. dmode: 0 idle,1 slide,2 ltrim,3 rtrim.
                            for clip[i] in root.timeline-clips : blk := Rectangle {
                                x: (clip.start * root.timeline-pps) * 1px - lane.scroll;
                                // track 0 = GES layer 0 = top (both on-screen and composited).
                                y: clip.track * 30px + 4px;
                                width: (clip.duration * root.timeline-pps) * 1px;
                                height: 22px;
                                background: transparent;
                                property <length> ddx: 0px;
                                property <length> ddy: 0px;
                                property <int> dmode: 0;

                                // live visual (previews the drag; not a drag frame)
                                vis := Rectangle {
                                    x: (blk.dmode == 1 || blk.dmode == 2) ? blk.ddx : 0px;
                                    y: blk.dmode == 1 ? blk.ddy : 0px;
                                    width: max(10px, parent.width
                                        + (blk.dmode == 2 ? -blk.ddx : 0px)
                                        + (blk.dmode == 3 ? blk.ddx : 0px));
                                    height: parent.height;
                                    border-radius: 6px;
                                    clip: true;
                                    background: clip.kind == 0
                                        ? @linear-gradient(135deg, #3f7df5 0%, #1f4fc0 100%)
                                        : @linear-gradient(135deg, #1fd3b6 0%, #0f9d84 100%);
                                    border-width: clip.selected ? 2px : 1px;
                                    border-color: clip.selected ? #2dd4bf : #00000055;
                                    // thumbnail (covers the gradient once generated)
                                    Image { source: clip.thumb; image-fit: cover; width: 100%; height: 100%; }
                                    // left scrim so the name stays legible over the thumb
                                    Rectangle { x: 0; width: 62%; background: @linear-gradient(90deg, #000000bb 0%, #00000000 100%); }
                                    Text { text: clip.name; color: white; font-size: 9px; font-weight: 700; x: 9px; y: (parent.height - self.height) / 2; }
                                    Rectangle { x: 0; width: 5px; height: parent.height; background: #ffffffcc; }
                                    Rectangle { x: parent.width - 5px; width: 5px; height: parent.height; background: #ffffffcc; }
                                }

                                // body: slide (horizontal) + move to another track
                                // (vertical) + select. Stable frame = blk.
                                TouchArea {
                                    mouse-cursor: move;
                                    moved => {
                                        blk.dmode = 1;
                                        blk.ddx = self.mouse-x - self.pressed-x;
                                        blk.ddy = self.mouse-y - self.pressed-y;
                                        root.clip-dragging = true;
                                        root.clip-drag-target-row = clip.track + Math.round(blk.ddy / 30px);
                                    }
                                    pointer-event(ev) => {
                                        if (ev.kind == PointerEventKind.up) {
                                            if (blk.dmode == 1 && (Math.abs(blk.ddx / 1px) > 2 || Math.abs(blk.ddy / 1px) > 2)) {
                                                root.timeline-clip-dropped(i, (blk.ddx / 1px) / root.timeline-pps, Math.round(blk.ddy / 30px));
                                            }
                                            blk.dmode = 0; blk.ddx = 0px; blk.ddy = 0px;
                                            root.clip-dragging = false;
                                        }
                                    }
                                    clicked => { root.timeline-select(i); }
                                }
                                // left-edge trim (on top of the body)
                                Rectangle {
                                    x: 0; width: 8px; height: parent.height; background: transparent;
                                    TouchArea {
                                        mouse-cursor: ew-resize;
                                        moved => { blk.dmode = 2; blk.ddx = self.mouse-x - self.pressed-x; }
                                        pointer-event(ev) => {
                                            if (ev.kind == PointerEventKind.up) {
                                                if (blk.dmode == 2 && Math.abs(blk.ddx / 1px) > 2) {
                                                    root.timeline-clip-trimmed(i, -1, (blk.ddx / 1px) / root.timeline-pps);
                                                }
                                                blk.dmode = 0; blk.ddx = 0px;
                                            }
                                        }
                                    }
                                }
                                // right-edge trim
                                Rectangle {
                                    x: parent.width - 8px; width: 8px; height: parent.height; background: transparent;
                                    TouchArea {
                                        mouse-cursor: ew-resize;
                                        moved => { blk.dmode = 3; blk.ddx = self.mouse-x - self.pressed-x; }
                                        pointer-event(ev) => {
                                            if (ev.kind == PointerEventKind.up) {
                                                if (blk.dmode == 3 && Math.abs(blk.ddx / 1px) > 2) {
                                                    root.timeline-clip-trimmed(i, 1, (blk.ddx / 1px) / root.timeline-pps);
                                                }
                                                blk.dmode = 0; blk.ddx = 0px;
                                            }
                                        }
                                    }
                                }
                            }

                            // playhead
                            Rectangle {
                                x: (root.playhead * root.timeline-pps) * 1px - lane.scroll;
                                width: 2px; height: parent.height;
                                background: #ff5470;
                            }

                            // horizontal scrollbar (only when the timeline overflows)
                            if lane.max-scroll > 0px : Rectangle {
                                y: parent.height - 11px; x: 4px; width: parent.width - 8px; height: 7px;
                                border-radius: 3px; background: #00000080;
                                property <length> thumb-w: max(36px, self.width * self.width / lane.content-w);
                                Rectangle {
                                    x: (lane.scroll / lane.max-scroll) * (parent.width - parent.thumb-w);
                                    width: parent.thumb-w; height: parent.height;
                                    border-radius: 3px;
                                    background: sbta.pressed ? #2dd4bf : (sbta.has-hover ? #ffffff66 : #ffffff40);
                                }
                                sbta := TouchArea {
                                    function set(mx: length) {
                                        root.tl-scroll = Math.clamp((mx - parent.thumb-w / 2) / (parent.width - parent.thumb-w) * lane.max-scroll, 0px, lane.max-scroll);
                                    }
                                    moved => { sbta.set(self.mouse-x); }
                                    pointer-event(ev) => { if (ev.kind == PointerEventKind.down) { sbta.set(self.mouse-x); } }
                                }
                            }
                        }
                    }
                }
            }
        }
    }

    // Import progress modal — overlays everything while files are being imported.
    if root.importing : Rectangle {
        background: #000000b0;
        // Swallow clicks behind the modal.
        TouchArea {}
        Rectangle {
            width: 320px; height: 128px;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            background: #1b1f27;
            border-radius: 12px;
            border-width: 1px; border-color: #2c313b;
            VerticalLayout {
                padding: 22px; spacing: 16px;
                Text {
                    text: "Importing files…";
                    color: #f2f4f8; font-size: 14px; font-weight: 700;
                    horizontal-alignment: center;
                }
                Rectangle {
                    height: 8px; border-radius: 4px; background: #2c313b;
                    Rectangle {
                        x: 0; height: parent.height; border-radius: 4px;
                        width: root.import-total > 0 ? parent.width * root.import-done / root.import-total : 0px;
                        background: @linear-gradient(90deg, #3f7df5 0%, #2dd4bf 100%);
                    }
                }
                Text {
                    text: root.import-done + " / " + root.import-total;
                    color: #9aa3b2; font-size: 11px;
                    horizontal-alignment: center;
                }
            }
        }
    }

}
