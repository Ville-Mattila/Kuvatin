import { Button, ComboBox, ProgressIndicator, ListView, LineEdit, SpinBox, CheckBox } from "std-widgets.slint";

export struct FileRow {
    name: string,
    status: string,
    thumb: image,
    dims: string,
    cropped: bool,
}

// Palette ---------------------------------------------------------------
// window     #16181d
// card       #20242c   border #2c313b   radius 10px
// text       #f2f4f8   muted  #9aa3b2
// accent     #2dd4bf   (hover/pressed #14b8a6)
// danger     #f87171

// A clearly visible, fully custom quality slider (0..100). Replaces the
// std-widgets Slider, which rendered invisibly against the dark theme.
component QualitySlider inherits Rectangle {
    in-out property <int> value;
    // Pin the height: inside a layout a plain `height` is only a preferred size
    // and the slider would stretch to fill extra vertical space (dropping the
    // track to the middle). min/max keep it a fixed 24px row.
    min-height: 24px;
    max-height: 24px;
    horizontal-stretch: 1;
    // Do not absorb the panel's extra vertical space (that's the spacer's job);
    // otherwise the QUALITY group stretches and the slider drops to its middle.
    vertical-stretch: 0;

    // track
    Rectangle {
        y: parent.height / 2 - 3px;
        height: 6px;
        border-radius: 3px;
        background: #2c313b;
        // filled portion
        Rectangle {
            x: 0;
            width: parent.width * (root.value / 100.0);
            height: parent.height;
            border-radius: 3px;
            background: #2dd4bf;
        }
    }

    // knob
    Rectangle {
        width: 16px;
        height: 16px;
        border-radius: 8px;
        background: ta.has-hover || ta.pressed ? #e6fffb : white;
        border-width: 2px;
        border-color: #2dd4bf;
        y: parent.height / 2 - 8px;
        x: (root.width - 16px) * (root.value / 100.0);
    }

    ta := TouchArea {
        function set(mx: length) {
            root.value = Math.clamp(Math.round(mx / root.width * 100), 0, 100);
        }
        moved => { ta.set(ta.mouse-x); }
        clicked => { ta.set(ta.mouse-x); }
    }
}

// A card surface used for the two main panels.
component Card inherits Rectangle {
    background: #20242c;
    border-radius: 10px;
    border-width: 1px;
    border-color: #2c313b;
}

// Secondary (card-colored) button used for Add/Clear.
component SecondaryButton inherits Rectangle {
    in property <string> text;
    callback clicked();
    height: 34px;
    min-width: 96px;
    border-radius: 8px;
    border-width: 1px;
    border-color: #2c313b;
    background: ta.pressed ? #2c313b : (ta.has-hover ? #262b34 : #20242c);
    Text {
        text: root.text;
        color: #f2f4f8;
        font-size: 13px;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
    ta := TouchArea {
        clicked => { root.clicked(); }
    }
}

// Field label: bold, muted.
component FieldLabel inherits Text {
    color: #9aa3b2;
    font-size: 12px;
    font-weight: 700;
}

// One resize handle for a corner of the crop rectangle. It owns its own drag
// bookkeeping (start values captured on press) and reports the dragged corner
// position back as normalized deltas via the `dragged` callback.
component CropHandle inherits Rectangle {
    in property <float> box-w;
    in property <float> box-h;
    // Which corner: -1 = left/top edge moves, +1 = right/bottom edge moves.
    in property <float> sign-x;
    in property <float> sign-y;
    // Fired when the drag starts, so the owner can capture the edges to offset.
    callback pressed();
    // dx, dy are normalized (0..1) drag deltas since press.
    callback dragged(float, float);

    // Large transparent hit area so the corner is easy to grab; the visible
    // square is centered within it. The TouchArea fills `root`.
    width: 32px;
    height: 32px;
    background: transparent;

    property <length> sx;
    property <length> sy;

    // Visible handle: a smaller teal square with a dark outline, centered.
    Rectangle {
        width: 18px;
        height: 18px;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        border-radius: 5px;
        background: ha.pressed ? #14b8a6 : #2dd4bf;
        border-width: 2px;
        border-color: #08110f;
    }

    ha := TouchArea {
        mouse-cursor: move;
        pointer-event(ev) => {
            if (ev.kind == PointerEventKind.down) {
                root.sx = self.mouse-x;
                root.sy = self.mouse-y;
                root.pressed();
            }
        }
        moved => {
            root.dragged(
                (self.mouse-x - root.sx) / (root.box-w * 1px),
                (self.mouse-y - root.sy) / (root.box-h * 1px),
            );
        }
    }
}

// A window-control button for the custom title bar. The icon is drawn as a
// vector shape (not a font glyph) so it stays crisp: kind = "min" | "max" | "close".
component WinButton inherits Rectangle {
    in property <string> kind;
    in property <bool> danger: false;
    callback clicked();
    width: 46px;
    background: ta.has-hover ? (root.danger ? #e23b3b : #2c313b) : transparent;
    property <color> ink: ta.has-hover && root.danger ? #ffffff : #c8ccd4;

    // Minimize: a single horizontal line.
    if root.kind == "min": Rectangle {
        width: 11px;
        height: 1px;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        background: root.ink;
    }
    // Maximize: a square outline.
    if root.kind == "max": Rectangle {
        width: 10px;
        height: 10px;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        border-width: 1px;
        border-color: root.ink;
        background: transparent;
    }
    // Close: an X drawn as two diagonal strokes.
    if root.kind == "close": Path {
        width: 11px;
        height: 11px;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        stroke: root.ink;
        stroke-width: 1.2px;
        viewbox-width: 100;
        viewbox-height: 100;
        MoveTo { x: 0; y: 0; }
        LineTo { x: 100; y: 100; }
        MoveTo { x: 100; y: 0; }
        LineTo { x: 0; y: 100; }
    }

    ta := TouchArea {
        clicked => { root.clicked(); }
    }
}

// A clean segmented control: a rounded track with the active segment as a
// rounded-rect that fills its slice. Used for the mode and the View/Crop toggles.
component SegToggle inherits Rectangle {
    in property <[string]> labels;
    in property <int> selected;
    callback select(int);
    height: 28px;
    border-radius: 8px;
    background: #14171c;
    border-width: 1px;
    border-color: #2c313b;
    HorizontalLayout {
        padding: 3px;
        spacing: 0px;
        for seg[i] in root.labels: Rectangle {
            horizontal-stretch: 1;
            border-radius: 6px;
            background: root.selected == i ? #2dd4bf : (ta.has-hover ? #20242c : transparent);
            animate background { duration: 120ms; }
            Text {
                text: seg;
                horizontal-alignment: center;
                vertical-alignment: center;
                font-size: 12.5px;
                font-weight: 600;
                color: root.selected == i ? #08110f : #9aa3b2;
            }
            ta := TouchArea { clicked => { root.select(i); } }
        }
    }
}

// A draggable vertical divider between body panels. Emits the horizontal drag
// delta since press; the parent clamps it onto a panel width. (The divider moves
// with the resized panel, so the per-event delta self-converges to track the cursor.)
component Splitter inherits Rectangle {
    callback dragged(length);
    width: 12px;
    background: transparent;
    Rectangle {
        width: 2px;
        height: 56%;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        border-radius: 1px;
        background: sta.has-hover || sta.pressed ? #2dd4bf : #2c313b;
        animate background { duration: 120ms; }
    }
    sta := TouchArea {
        mouse-cursor: ew-resize;
        moved => { root.dragged(self.mouse-x - self.pressed-x); }
    }
}

// A compact popover number editor used by the inline crop toolbar. The
// displayed value is computed by the caller (one-way `value`); typing a number
// and pressing Enter fires `edited(int)` with the value clamped to [min,max].
// Callback-based (not two-way bound to a computed property) to avoid binding
// loops.
component NumberDropdown inherits Rectangle {
    in property <string> label;
    in property <int> value;        // display value (computed by caller, one-way)
    in property <int> minimum: 0;
    in property <int> maximum: 100000;
    callback edited(int);           // fires with the new clamped value
    property <bool> open: false;
    width: 66px; height: 24px; border-radius: 6px;
    background: #16181d; border-width: 1px; border-color: #343b46;
    HorizontalLayout {
        padding-left: 6px; padding-right: 6px;
        Text { text: root.label + " " + root.value; color: #e6e9ef; font-size: 10px; vertical-alignment: center; }
    }
    ta := TouchArea { clicked => { root.open = !root.open; } }
    if root.open : Rectangle {
        y: parent.height + 3px; width: 92px; height: 30px;
        background: #20242c; border-radius: 6px; border-width: 1px; border-color: #343b46;
        LineEdit {
            width: 84px; x: 4px; y: 3px;
            text: root.value;
            input-type: number;
            accepted(t) => {
                root.edited(Math.clamp(t.to-float(), root.minimum, root.maximum));
                root.open = false;
            }
        }
    }
}

// A thin 0..1 slider used for the video scrubber and volume. Reports the new
// fraction via `changed` on click or drag.
component Scrubber inherits Rectangle {
    in property <float> value;     // 0..1
    callback changed(float);
    min-height: 18px;
    max-height: 18px;
    horizontal-stretch: 1;
    Rectangle {
        y: parent.height / 2 - 3px;
        height: 6px;
        border-radius: 3px;
        background: #2c313b;
        Rectangle {
            x: 0;
            width: parent.width * Math.clamp(root.value, 0, 1);
            height: parent.height;
            border-radius: 3px;
            background: #2dd4bf;
        }
    }
    Rectangle {
        width: 12px;
        height: 12px;
        border-radius: 6px;
        background: sta.has-hover || sta.pressed ? #e6fffb : white;
        border-width: 2px;
        border-color: #2dd4bf;
        y: parent.height / 2 - 6px;
        x: (root.width - 12px) * Math.clamp(root.value, 0, 1);
    }
    sta := TouchArea {
        function emit(mx: length) { root.changed(Math.clamp(mx / root.width, 0, 1)); }
        moved => { sta.emit(sta.mouse-x); }
        clicked => { sta.emit(sta.mouse-x); }
    }
}

export component AppWindow inherits Window {
    title: "Kuvatin";
    icon: @image-url("../assets/kuvatin-icon.png");
    no-frame: true;
    preferred-width: 1320px;
    preferred-height: 840px;
    min-width: 860px;
    min-height: 560px;
    background: #16181d;

    in property <[FileRow]> files;
    in property <[string]> preset-names;
    in property <bool> running: false;
    in property <float> progress: 0.0;
    in-out property <int> current-preset: 0;
    in-out property <string> format: "webp";
    in-out property <int> quality: 80;
    // PNG optimization mode: 0 = Normal, 1 = Optimize (lossless), 2 = Compress (lossy).
    in-out property <int> png-mode: 0;
    in-out property <string> preset-name;
    // 0 = Images, 1 = Videos. Video mode is a placeholder until the GStreamer plan.
    in-out property <int> app-mode: 0;
    // Adjustable side-panel widths (drag the splitters between cards). The viewer
    // takes the remaining space.
    in-out property <length> files-w: 280px;
    in-out property <length> settings-w: 340px;

    // Video mode state (set from Rust) and actions.
    in property <image> video-frame;
    in-out property <bool> video-playing: false;
    in property <float> video-position: 0.0;        // 0..1 along the clip
    in property <string> video-time: "0:00 / 0:00";
    in-out property <float> video-volume: 1.0;       // 0..1
    in property <[string]> video-clips;
    in-out property <int> video-selected: -1;
    callback video-open();
    callback video-select(int);
    callback video-playpause();
    callback video-seek(float);            // fraction 0..1
    callback video-volume-changed(float);  // 0..1

    // Crop editor state. The crop rectangle is stored in NORMALIZED coordinates
    // (0..1) relative to the displayed image, so the preview size is irrelevant —
    // Rust maps normalized → absolute pixels using the original image dimensions.
    in-out property <bool> cropping: false;
    in property <float> crop-box-w: 400;   // preview box size in px (matches image aspect)
    in property <float> crop-box-h: 300;
    in-out property <float> crop-x: 0;
    in-out property <float> crop-y: 0;
    in-out property <float> crop-w: 1;
    in-out property <float> crop-h: 1;
    in-out property <bool> aspect-lock: false;
    // Original (full-resolution) dimensions of the image being cropped, so the
    // numeric X/Y/W/H fields can be shown and edited in absolute pixels.
    in property <int> crop-img-w;
    in property <int> crop-img-h;

    // Output-resolution override (Settings panel). 0 means "use preset size".
    in-out property <int> res-w: 0;
    in-out property <int> res-h: 0;
    in-out property <bool> res-lock: true;

    // Default suffix appended to output file names (e.g. "photo-kuvatin.webp").
    // Seeds the Save dialog name for one file and is applied to every file when
    // converting a batch into a chosen folder. Saved with the preset.
    in-out property <string> suffix: "-kuvatin";
    // When set, outputs go into a subfolder named after the suffix.
    in-out property <bool> save-subfolder: false;

    // Custom window-frame controls (frameless window; wired to Win32 in gui.rs).
    callback win-minimize();
    callback win-maximize();
    callback win-close();
    callback win-drag();

    callback add-files();
    callback clear-files();
    callback preset-changed(int);
    callback convert();
    callback save-preset(string);
    callback delete-preset();
    callback apply-crop();

    // Central image viewer.
    in-out property <int> selected-index: -1;
    in property <image> viewer-image;
    callback select-file(int);

    VerticalLayout {
        padding: 0px;
        spacing: 0px;

        // Custom title bar ----------------------------------------------
        Rectangle {
            min-height: 36px;
            max-height: 36px;
            background: #16181d;

            // Dragging is handled natively via WM_NCHITTEST (HTCAPTION) in the
            // Win32 subclass; the window buttons stay clickable (HTCLIENT).
            HorizontalLayout {
                padding-left: 12px;
                spacing: 8px;

                Image {
                    source: @image-url("../assets/kuvatin-icon.svg");
                    width: 20px;
                    height: 20px;
                    y: (parent.height - self.height) / 2;
                }
                Text {
                    text: "Kuvatin";
                    color: #f2f4f8;
                    font-size: 14px;
                    font-weight: 800;
                    vertical-alignment: center;
                }

                Rectangle { horizontal-stretch: 1; }

                WinButton { kind: "min"; clicked => { root.win-minimize(); } }
                WinButton { kind: "max"; clicked => { root.win-maximize(); } }
                WinButton { kind: "close"; danger: true; clicked => { root.win-close(); } }
            }
        }

        // Mode toggle bar — below the titlebar (client area) so clicks register.
        // In the titlebar, the native drag hit-test (HTCAPTION) swallows clicks.
        Rectangle {
            height: 42px;
            background: #16181d;
            SegToggle {
                width: 184px;
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;
                labels: ["Images", "Videos"];
                selected: root.app-mode;
                select(i) => { root.app-mode = i; }
            }
        }

        // Body -----------------------------------------------------------
        if root.app-mode == 0: HorizontalLayout {
            padding: 16px;
            spacing: 0px;

            // Files card
            Card {
                width: root.files-w;
                clip: true;
                VerticalLayout {
                    padding: 16px;
                    spacing: 12px;

                    Text {
                        text: "Files";
                        color: #f2f4f8;
                        font-size: 15px;
                        font-weight: 700;
                    }

                    // list / empty-state
                    Rectangle {
                        vertical-stretch: 1;
                        background: #181b21;
                        border-radius: 8px;
                        border-width: 1px;
                        border-color: #2c313b;

                        // empty-state
                        if root.files.length == 0: VerticalLayout {
                            alignment: center;
                            spacing: 16px;

                            // Minimalist line-art image glyph in the app accent:
                            // a rounded frame with a sun and a mountain.
                            HorizontalLayout {
                                alignment: center;
                                Rectangle {
                                    width: 64px;
                                    height: 64px;
                                    border-radius: 14px;
                                    border-width: 2px;
                                    border-color: #2dd4bf;
                                    background: transparent;
                                    clip: true;
                                    // sun
                                    Rectangle {
                                        width: 13px;
                                        height: 13px;
                                        border-radius: 7px;
                                        x: 14px;
                                        y: 14px;
                                        background: #2dd4bf;
                                    }
                                    // mountains rising from the bottom edge
                                    Path {
                                        width: 64px;
                                        height: 64px;
                                        viewbox-width: 64;
                                        viewbox-height: 64;
                                        fill: #2dd4bf;
                                        commands: "M0 64 L24 36 L37 49 L48 32 L64 52 L64 64 Z";
                                    }
                                }
                            }
                            Text {
                                text: "Drop images here\nor click Add files…";
                                color: #9aa3b2;
                                font-size: 13px;
                                horizontal-alignment: center;
                            }
                        }

                        // populated list
                        if root.files.length > 0: ListView {
                            for row[i] in root.files: Rectangle {
                                height: 44px;
                                background: root.selected-index == i
                                    ? #2dd4bf18
                                    : (row-ta.has-hover ? #262b34 : (Math.mod(i, 2) == 0 ? transparent : #1c2027));
                                row-ta := TouchArea {
                                    clicked => { root.select-file(i); }
                                }
                                HorizontalLayout {
                                    padding-left: 12px;
                                    padding-right: 14px;
                                    spacing: 10px;

                                    // thumbnail with a subtle rounded backing
                                    Rectangle {
                                        width: 40px;
                                        height: 40px;
                                        y: (parent.height - self.height) / 2;
                                        border-radius: 6px;
                                        background: #181b21;
                                        border-width: 1px;
                                        border-color: #2c313b;
                                        clip: true;
                                        Image {
                                            source: row.thumb;
                                            width: 40px;
                                            height: 40px;
                                            image-fit: contain;
                                        }
                                    }

                                    Text {
                                        text: row.name;
                                        color: #f2f4f8;
                                        font-size: 13px;
                                        vertical-alignment: center;
                                        horizontal-stretch: 1;
                                        overflow: elide;
                                    }
                                    Text {
                                        text: row.dims;
                                        color: #9aa3b2;
                                        font-size: 11px;
                                        vertical-alignment: center;
                                    }
                                    Rectangle {
                                        visible: row.cropped;
                                        height: 16px; border-radius: 999px; background: #2dd4bf;
                                        y: (parent.height - self.height) / 2;
                                        HorizontalLayout {
                                            padding-left: 6px; padding-right: 6px;
                                            Text { text: "crop"; color: #08110f; font-size: 9px; font-weight: 700; vertical-alignment: center; }
                                        }
                                    }
                                    Text {
                                        text: row.status;
                                        color: row.status == "done"
                                            ? #2dd4bf
                                            : (row.status == "error" ? #f87171 : #9aa3b2);
                                        font-size: 12px;
                                        vertical-alignment: center;
                                    }
                                }
                            }
                        }
                    }

                    HorizontalLayout {
                        spacing: 10px;
                        SecondaryButton {
                            text: "Add files…";
                            clicked => { root.add-files(); }
                        }
                        SecondaryButton {
                            text: "Clear";
                            clicked => { root.clear-files(); }
                        }
                        Rectangle { horizontal-stretch: 1; }
                    }
                }
            }

            // Lower bound = the Files list's content width; upper bound keeps the
            // viewer at >= its min so nothing is squeezed off-screen.
            Splitter { dragged(dx) => {
                root.files-w = Math.clamp(root.files-w + dx, 200px, root.width - root.settings-w - 296px);
            } }

            // Viewer card
            Card {
                min-width: 240px;
                horizontal-stretch: 1;
                clip: true;
                VerticalLayout {
                    padding: 12px; spacing: 8px;

                    Text { text: "Preview"; color: #f2f4f8; font-size: 15px; font-weight: 700; }

                    // Toolbar: View/Crop toggle + (when cropping) numeric crop
                    // controls and the aspect-lock button.
                    HorizontalLayout {
                        height: 28px;
                        spacing: 8px;

                        // View / Crop segmented toggle. Selecting Crop enters crop
                        // mode; selecting View applies the current crop then exits.
                        SegToggle {
                            width: 132px;
                            labels: ["View", "Crop"];
                            selected: root.cropping ? 1 : 0;
                            select(i) => {
                                if (i == 0) {
                                    if (root.cropping) { root.apply-crop(); }
                                    root.cropping = false;
                                } else {
                                    root.cropping = true;
                                }
                            }
                        }

                        Rectangle { horizontal-stretch: 1; }

                        if root.cropping : HorizontalLayout {
                            spacing: 6px;
                            NumberDropdown { label: "X"; value: round(root.crop-x * root.crop-img-w); maximum: root.crop-img-w - 1;
                                edited(v) => { root.crop-x = Math.clamp(v / Math.max(root.crop-img-w, 1), 0.0, 1.0 - root.crop-w); } }
                            NumberDropdown { label: "Y"; value: round(root.crop-y * root.crop-img-h); maximum: root.crop-img-h - 1;
                                edited(v) => { root.crop-y = Math.clamp(v / Math.max(root.crop-img-h, 1), 0.0, 1.0 - root.crop-h); } }
                            NumberDropdown { label: "W"; value: round(root.crop-w * root.crop-img-w); minimum: 1; maximum: root.crop-img-w;
                                edited(v) => { root.crop-w = Math.clamp(v / Math.max(root.crop-img-w, 1), 0.0, 1.0 - root.crop-x); } }
                            NumberDropdown { label: "H"; value: round(root.crop-h * root.crop-img-h); minimum: 1; maximum: root.crop-img-h;
                                edited(v) => { root.crop-h = Math.clamp(v / Math.max(root.crop-img-h, 1), 0.0, 1.0 - root.crop-y); } }
                            Rectangle {
                                width: 26px; border-radius: 6px;
                                background: root.aspect-lock ? #2dd4bf : #16181d;
                                border-width: 1px; border-color: #343b46;
                                Text { text: "🔒"; font-size: 11px; horizontal-alignment: center; vertical-alignment: center; }
                                TouchArea { clicked => { root.aspect-lock = !root.aspect-lock; } }
                            }
                        }
                    }

                    // Crop surface: hosts the preview and the inline crop editor.
                    // The crop math (ported verbatim from the modal) works in the
                    // crop-box-w/h coordinate system, so the crop UI is rendered as
                    // a CENTERED region of exactly crop-box-w × crop-box-h px — the
                    // same coordinate system the modal uses.
                    crop-surface := Rectangle {
                        vertical-stretch: 1;
                        background: #0b0d11;
                        border-radius: 8px;
                        border-width: 1.5px;
                        border-color: #2dd4bf;
                        clip: true;

                        // Minimum normalized rect size, so a rectangle can't collapse.
                        property <float> min-n: 0.03;

                        // Drag bookkeeping for moving the whole rectangle.
                        property <length> move-sx;
                        property <length> move-sy;
                        property <float> move-x0;
                        property <float> move-y0;

                        // Edge values captured at the start of a corner drag.
                        property <float> edge-l;
                        property <float> edge-t;
                        property <float> edge-r;
                        property <float> edge-b;
                        // Aspect ratio (w:h in box pixels) captured for aspect-lock resizing.
                        property <float> edge-ratio;

                        function begin-corner() {
                            self.edge-l = root.crop-x;
                            self.edge-t = root.crop-y;
                            self.edge-r = root.crop-x + root.crop-w;
                            self.edge-b = root.crop-y + root.crop-h;
                            self.edge-ratio = (root.crop-w * root.crop-box-w) / (root.crop-h * root.crop-box-h);
                        }

                        // Apply a corner drag. sgx/sgy pick which edges move (-1 left/top, +1 right/bottom).
                        function corner(sgx: float, sgy: float, dx: float, dy: float) {
                            // Horizontal edge.
                            if (sgx < 0) {
                                self.edge-l = Math.clamp(self.edge-l + dx, 0, self.edge-r - self.min-n);
                            } else {
                                self.edge-r = Math.clamp(self.edge-r + dx, self.edge-l + self.min-n, 1);
                            }
                            // Vertical edge.
                            if (sgy < 0) {
                                self.edge-t = Math.clamp(self.edge-t + dy, 0, self.edge-b - self.min-n);
                            } else {
                                self.edge-b = Math.clamp(self.edge-b + dy, self.edge-t + self.min-n, 1);
                            }

                            root.crop-x = self.edge-l;
                            root.crop-y = self.edge-t;
                            root.crop-w = self.edge-r - self.edge-l;
                            root.crop-h = self.edge-b - self.edge-t;

                            if (root.aspect-lock && self.edge-ratio > 0) {
                                // Recompute height from width to preserve the on-screen aspect:
                                // crop-w*box-w : crop-h*box-h == edge-ratio. Solve for crop-h.
                                root.crop-h = (root.crop-w * root.crop-box-w) / (self.edge-ratio * root.crop-box-h);
                                // Grow/shrink from the anchored corner (the edge that did NOT move).
                                if (sgy < 0) {
                                    root.crop-y = self.edge-b - root.crop-h;
                                }
                                // Clamp the derived height into bounds; if it overflows, fall back
                                // to a height that fits and re-anchor.
                                if (root.crop-y < 0) {
                                    root.crop-y = 0;
                                    root.crop-h = self.edge-b;
                                }
                                if (root.crop-y + root.crop-h > 1) {
                                    root.crop-h = 1 - root.crop-y;
                                }
                            }
                        }

                        if root.selected-index < 0: Text {
                            text: "Select a file to preview";
                            color: #6b7585; font-size: 13px;
                            horizontal-alignment: center; vertical-alignment: center;
                        }

                        // Plain preview when not cropping.
                        if root.selected-index >= 0 && !root.cropping: Image {
                            source: root.viewer-image;
                            image-fit: contain;
                            width: 100%; height: 100%;
                        }

                        // Inline crop editor: a centered crop-box-w × crop-box-h
                        // region holding the image, with the modal's dim strips,
                        // crop rectangle, move handle and four corner handles —
                        // ported verbatim (parent-overlay → crop-surface).
                        if root.selected-index >= 0 && root.cropping: cbox := Rectangle {
                            x: (parent.width - self.width) / 2;
                            y: (parent.height - self.height) / 2;
                            width: root.crop-box-w * 1px;
                            height: root.crop-box-h * 1px;
                            border-radius: 6px;
                            clip: true;

                            Image {
                                source: root.viewer-image;
                                width: 100%;
                                height: 100%;
                                image-fit: fill;
                            }

                            // Dim overlay outside the crop selection (four strips).
                            Rectangle { x: 0; y: 0; width: parent.width; height: root.crop-y * parent.height; background: #00000099; }
                            Rectangle { x: 0; y: (root.crop-y + root.crop-h) * parent.height; width: parent.width; height: parent.height - (root.crop-y + root.crop-h) * parent.height; background: #00000099; }
                            Rectangle { x: 0; y: root.crop-y * parent.height; width: root.crop-x * parent.width; height: root.crop-h * parent.height; background: #00000099; }
                            Rectangle { x: (root.crop-x + root.crop-w) * parent.width; y: root.crop-y * parent.height; width: parent.width - (root.crop-x + root.crop-w) * parent.width; height: root.crop-h * parent.height; background: #00000099; }

                            // The crop rectangle border + move handle.
                            crect := Rectangle {
                                x: root.crop-x * parent.width;
                                y: root.crop-y * parent.height;
                                width: root.crop-w * parent.width;
                                height: root.crop-h * parent.height;
                                border-width: 2px;
                                border-color: #2dd4bf;

                                cmove-ta := TouchArea {
                                    mouse-cursor: move;
                                    pointer-event(ev) => {
                                        if (ev.kind == PointerEventKind.down) {
                                            crop-surface.move-sx = self.mouse-x;
                                            crop-surface.move-sy = self.mouse-y;
                                            crop-surface.move-x0 = root.crop-x;
                                            crop-surface.move-y0 = root.crop-y;
                                        }
                                    }
                                    moved => {
                                        root.crop-x = Math.clamp(
                                            crop-surface.move-x0 + (self.mouse-x - crop-surface.move-sx) / (root.crop-box-w * 1px),
                                            0, 1 - root.crop-w);
                                        root.crop-y = Math.clamp(
                                            crop-surface.move-y0 + (self.mouse-y - crop-surface.move-sy) / (root.crop-box-h * 1px),
                                            0, 1 - root.crop-h);
                                    }
                                }
                            }

                            // Four corner resize handles. Inset so the full handle
                            // stays visible at each corner. Each reports normalized
                            // drag deltas.
                            CropHandle {
                                x: root.crop-x * cbox.width;
                                y: root.crop-y * cbox.height;
                                box-w: root.crop-box-w; box-h: root.crop-box-h;
                                sign-x: -1; sign-y: -1;
                                pressed => { crop-surface.begin-corner(); }
                                dragged(dx, dy) => { crop-surface.corner(-1, -1, dx, dy); }
                            }
                            CropHandle {
                                x: (root.crop-x + root.crop-w) * cbox.width - self.width;
                                y: root.crop-y * cbox.height;
                                box-w: root.crop-box-w; box-h: root.crop-box-h;
                                sign-x: 1; sign-y: -1;
                                pressed => { crop-surface.begin-corner(); }
                                dragged(dx, dy) => { crop-surface.corner(1, -1, dx, dy); }
                            }
                            CropHandle {
                                x: root.crop-x * cbox.width;
                                y: (root.crop-y + root.crop-h) * cbox.height - self.height;
                                box-w: root.crop-box-w; box-h: root.crop-box-h;
                                sign-x: -1; sign-y: 1;
                                pressed => { crop-surface.begin-corner(); }
                                dragged(dx, dy) => { crop-surface.corner(-1, 1, dx, dy); }
                            }
                            CropHandle {
                                x: (root.crop-x + root.crop-w) * cbox.width - self.width;
                                y: (root.crop-y + root.crop-h) * cbox.height - self.height;
                                box-w: root.crop-box-w; box-h: root.crop-box-h;
                                sign-x: 1; sign-y: 1;
                                pressed => { crop-surface.begin-corner(); }
                                dragged(dx, dy) => { crop-surface.corner(1, 1, dx, dy); }
                            }
                        }
                    }
                }
            }

            // Lower bound = the Settings form's content width (the widest row is
            // the "Save to a subfolder…" label); upper bound keeps the viewer alive.
            Splitter { dragged(dx) => {
                root.settings-w = Math.clamp(root.settings-w - dx, 330px, root.width - root.files-w - 296px);
            } }

            // Settings card
            Card {
                width: root.settings-w;
                clip: true;
                VerticalLayout {
                    padding: 16px;
                    spacing: 14px;

                    Text {
                        text: "Settings";
                        color: #f2f4f8;
                        font-size: 15px;
                        font-weight: 700;
                    }

                    VerticalLayout {
                        spacing: 6px;
                        FieldLabel { text: "PRESET"; }
                        ComboBox {
                            model: root.preset-names;
                            current-index <=> root.current-preset;
                            selected => { root.preset-changed(self.current-index); }
                        }
                        HorizontalLayout {
                            spacing: 8px;
                            LineEdit {
                                placeholder-text: "Preset name";
                                text <=> root.preset-name;
                                horizontal-stretch: 1;
                            }
                            SecondaryButton {
                                text: "Save";
                                min-width: 72px;
                                clicked => { root.save-preset(root.preset-name); }
                            }
                            SecondaryButton {
                                text: "Delete";
                                min-width: 72px;
                                clicked => { root.delete-preset(); }
                            }
                        }
                    }

                    VerticalLayout {
                        spacing: 6px;
                        FieldLabel { text: "FORMAT"; }
                        ComboBox {
                            model: ["png", "jpeg", "webp", "bmp", "tiff", "gif"];
                            current-value <=> root.format;
                        }
                    }

                    // PNG size optimization (only relevant for PNG output).
                    if root.format == "png": VerticalLayout {
                        spacing: 6px;
                        FieldLabel { text: "PNG OPTIMIZATION"; }
                        ComboBox {
                            model: ["Normal", "Optimize (lossless)", "Compress (lossy · uses quality)"];
                            current-index <=> root.png-mode;
                        }
                    }

                    // Quality only applies to lossy outputs: JPEG, WebP, and PNG
                    // in "Compress (lossy)" mode (png-mode == 2).
                    if root.format == "jpeg" || root.format == "webp"
                        || (root.format == "png" && root.png-mode == 2): VerticalLayout {
                        spacing: 6px;
                        FieldLabel { text: "QUALITY (\{root.quality})"; }
                        QualitySlider {
                            value <=> root.quality;
                        }
                    }

                    VerticalLayout {
                        spacing: 6px;
                        FieldLabel { text: "RESOLUTION (px)"; }
                        HorizontalLayout {
                            spacing: 10px;
                            VerticalLayout {
                                spacing: 2px;
                                FieldLabel { text: "WIDTH"; }
                                SpinBox {
                                    minimum: 0;
                                    maximum: 20000;
                                    value <=> root.res-w;
                                }
                            }
                            VerticalLayout {
                                spacing: 2px;
                                FieldLabel { text: "HEIGHT"; }
                                SpinBox {
                                    minimum: 0;
                                    maximum: 20000;
                                    value <=> root.res-h;
                                }
                            }
                        }
                        HorizontalLayout {
                            spacing: 8px;
                            CheckBox {
                                text: "Keep aspect";
                                checked <=> root.res-lock;
                            }
                            Rectangle { horizontal-stretch: 1; }
                        }
                        Text {
                            text: "0 = keep preset size";
                            color: #9aa3b2;
                            font-size: 11px;
                        }
                    }

                    VerticalLayout {
                        spacing: 6px;
                        FieldLabel { text: "FILE NAME SUFFIX"; }
                        LineEdit {
                            placeholder-text: "e.g. -kuvatin";
                            text <=> root.suffix;
                        }
                        CheckBox {
                            text: "Save to a subfolder (named after the suffix)";
                            checked <=> root.save-subfolder;
                        }
                    }

                    // spacer pushes the action block to the bottom
                    Rectangle { vertical-stretch: 1; }

                    if root.running: ProgressIndicator {
                        height: 6px;
                        progress: root.progress;
                    }

                    Rectangle {
                        height: 42px;
                        border-radius: 8px;
                        background: root.running
                            ? #1d6b62
                            : (convert-ta.pressed
                                ? #14b8a6
                                : (convert-ta.has-hover ? #14b8a6 : #2dd4bf));
                        Text {
                            text: root.running ? "Converting…" : "Convert";
                            color: root.running ? #9aa3b2 : #08110f;
                            font-size: 14px;
                            font-weight: 700;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                        convert-ta := TouchArea {
                            enabled: !root.running;
                            clicked => { root.convert(); }
                        }
                    }
                }
            }
        }
        if root.app-mode == 1: HorizontalLayout {
            padding: 16px;
            spacing: 16px;

            // Media panel
            Card {
                width: root.files-w;
                clip: true;
                VerticalLayout {
                    padding: 16px;
                    spacing: 12px;
                    Text { text: "Media"; color: #f2f4f8; font-size: 15px; font-weight: 700; }
                    Rectangle {
                        vertical-stretch: 1;
                        background: #181b21;
                        border-radius: 8px;
                        border-width: 1px;
                        border-color: #2c313b;
                        clip: true;
                        if root.video-clips.length == 0 : Text {
                            text: "No clips yet";
                            color: #6b7585; font-size: 12px;
                            horizontal-alignment: center; vertical-alignment: center;
                        }
                        if root.video-clips.length > 0 : ListView {
                            for clip[i] in root.video-clips : Rectangle {
                                height: 36px;
                                background: root.video-selected == i
                                    ? #2dd4bf18
                                    : (clip-ta.has-hover ? #262b34 : transparent);
                                clip-ta := TouchArea { clicked => { root.video-select(i); } }
                                HorizontalLayout {
                                    padding-left: 10px; padding-right: 10px;
                                    Text {
                                        text: clip; color: #f2f4f8; font-size: 12px;
                                        vertical-alignment: center; overflow: elide;
                                    }
                                }
                            }
                        }
                    }
                    SecondaryButton {
                        text: "Open video…";
                        clicked => { root.video-open(); }
                    }
                }
            }

            // Video preview
            Card {
                min-width: 240px;
                horizontal-stretch: 1;
                clip: true;
                VerticalLayout {
                    padding: 12px;
                    spacing: 8px;
                    Text { text: "Preview"; color: #f2f4f8; font-size: 15px; font-weight: 700; }
                    Rectangle {
                        vertical-stretch: 1;
                        background: #000;
                        border-radius: 8px;
                        border-width: 1.5px;
                        border-color: #2dd4bf;
                        clip: true;
                        if root.video-frame.width > 0 : Image {
                            source: root.video-frame;
                            image-fit: contain;
                            width: 100%; height: 100%;
                        }
                        if root.video-frame.width <= 0 : Text {
                            text: "Open a video to play";
                            color: #6b7585; font-size: 13px;
                            horizontal-alignment: center; vertical-alignment: center;
                        }
                    }

                    // Transport
                    HorizontalLayout {
                        height: 26px;
                        spacing: 10px;
                        Rectangle {
                            width: 30px;
                            border-radius: 6px;
                            background: pp-ta.has-hover ? #20242c : transparent;
                            Text {
                                text: root.video-playing ? "⏸" : "▶";
                                color: #e6e9ef; font-size: 14px;
                                horizontal-alignment: center; vertical-alignment: center;
                            }
                            pp-ta := TouchArea { clicked => { root.video-playpause(); } }
                        }
                        Text {
                            text: root.video-time;
                            color: #9aa3b2; font-size: 11px;
                            vertical-alignment: center;
                        }
                        Scrubber {
                            value: root.video-position;
                            changed(f) => { root.video-seek(f); }
                        }
                        Text { text: "🔊"; font-size: 12px; vertical-alignment: center; }
                        Scrubber {
                            width: 70px;
                            value: root.video-volume;
                            changed(f) => { root.video-volume-changed(f); }
                        }
                    }
                }
            }
        }
    }

}
